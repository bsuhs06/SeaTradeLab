DATABASE_URL=postgres://<user>:<password>@localhost:5432/ais_data?sslmode=disable
POLL_INTERVAL_MINUTES=15
LOG_LEVEL=info

# AIS Sources
ENABLE_DIGITRAFFIC=true
ENABLE_MOCK_SOURCE=false

# Optional: AISStream (register at aisstream.io)
# AISSTREAM_API_KEY=<your_api_key>

# Optional: AISHub (register at aishub.net)
# AISHUB_USERNAME=<your_username>
# AISHUB_BASE_URL=http://data.aishub.net/ws.php
